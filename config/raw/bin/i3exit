#!/bin/bash
# From:
# https://faq.i3wm.org/question/239/how-do-i-suspendlockscreen-and-logout.1.html
case "$1" in
    lock)
        swaylock
        ;;
    logout)
        swaymsg exit
        ;;
    suspend)
        swaylock -f && systemctl suspend
        ;;
    hibernate)
        swaylock -f && systemctl hibernate
        ;;
    reboot)
        systemctl reboot
        ;;
    shutdown)
        systemctl poweroff
        ;;
    *)
        echo "Usage: $0 {lock|logout|suspend|hibernate|reboot|shutdown}"
        exit 2
esac

exit 0
